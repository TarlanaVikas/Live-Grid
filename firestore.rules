rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can access documents
    match /documents/{docId} {
      allow read: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Cells subcollection - inherit document access
      match /cells/{cellId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/$(docId)).data.ownerId == request.auth.uid;
        allow write: if request.auth != null && get(/databases/$(database)/documents/$(docId)).data.ownerId == request.auth.uid;
      }
      
      // Presence subcollection - inherit document access
      match /presence/{userId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/$(docId)).data.ownerId == request.auth.uid;
        allow write: if request.auth != null && request.auth.uid == userId && get(/databases/$(database)/documents/$(docId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
